# genlayer-cli deploy environment
# (the CLI usually reads its keystore + network from ~/.genlayer instead of
# this file — this is only wired for scripted deploys that pass a raw key)

GENLAYER_STUDIO_URL=https://studio.genlayer.com/api

# Private key of the wallet that will deploy + own the contract.
# Never commit a real key. If you accidentally do, rotate immediately.
PRIVATE_KEY=
